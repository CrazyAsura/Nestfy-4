# ╔══════════════════════════════════════════════════════════════════════╗
# ║  NESTFY — Environment Variables Template                           ║
# ║  Copy this file to .env and fill in your values.                   ║
# ║                                                                    ║
# ║  cp .env.example .env                                              ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ────────────────────────── Network ──────────────────────────
COMPOSE_PROJECT_NAME=nestfy
NETWORK_NAME=Nestfy-network

# ────────────────────────── PostgreSQL ──────────────────────────
POSTGRES_USER=nestfy_admin
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=nestfy_db
POSTGRES_PORT=5433

# ────────────────────────── MongoDB ──────────────────────────
MONGO_INITDB_ROOT_USERNAME=nestfy_mongo_admin
MONGO_INITDB_ROOT_PASSWORD=CHANGE_ME
MONGO_INITDB_DATABASE=nestfy_nosql
MONGO_PORT=27017

# ────────────────────────── Redis ──────────────────────────
REDIS_PASSWORD=CHANGE_ME
REDIS_PORT=6380

# ────────────────────────── Kafka ──────────────────────────
KAFKA_BROKER_PORT=9094
KAFKA_CONTROLLER_PORT=9093
KAFKA_CLUSTER_ID=NestfyKafkaCluster2026

# ────────────────────────── Backend (Spring Boot) ──────────────────────────
BACKEND_PORT=8081
SPRING_PROFILES_ACTIVE=docker
JAVA_OPTS=-XX:+UseSerialGC -Xmx256m -XX:MaxMetaspaceSize=100m -XX:ReservedCodeCacheSize=64m -Xss256k -Dspring.main.lazy-initialization=true
SPRING_SECURITY_USER_NAME=super-admin@nestfy.com
SPRING_SECURITY_USER_PASSWORD=CHANGE_ME

# ────────────────────────── Frontend (Next.js) ──────────────────────────
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://backend:8080
NODE_ENV=production

# ────────────────────────── Local Tunneling Layer ──────────────────────────
# Expose local backend to public internet for Vercel failover.
# Set either CLOUDFLARE_TUNNEL_TOKEN (recommended) or NGROK_AUTHTOKEN.
CLOUDFLARE_TUNNEL_TOKEN=
NGROK_AUTHTOKEN=3BaDA140paMmgTmwxLRSHylhswJ_QxVGmEVsW8tVviEGUhuz
